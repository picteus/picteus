{
  "name": "@picteus/midjourney",
  "version": "1.1.0",
  "productName": "Midjourney",
  "description": "Accesses to all sorts of Midjourney features.",
  "keywords": [
    "picteus",
    "extension",
    "Midjourney"
  ],
  "author": {
    "name": "Édouard Mercier",
    "email": "edouard@koppasoft.com",
    "url": "https://github.com/edouardmercier"
  },
  "license": "GNU Affero General Public License",
  "private": false,
  "engines": {
    "node": ">=22.17.1"
  },
  "homepage": "https://github.com/picteus/Picteus",
  "repository": {
    "type": "git",
    "url": "https://github.com/picteus/Picteus.git"
  },
  "bugs": {
    "url": "https://github.com/picteus/Picteus/issues"
  },
  "type": "module",
  "main": "./dist/main.js",
  "files": [
    "dist",
    "manifest.json",
    "icon.png"
  ],
  "scripts": {
    "chrome-extension:prerequisites": "git submodule add --force git@github.com:picteus/picteus-chrome-extensions.git picteus-chrome-extensions",
    "chrome-extension:build": "npm --prefix picteus-chrome-extensions install && npm --prefix picteus-chrome-extensions run midjourney:package -- $(npm prefix)/dist",
    "self:build": "tsc",
    "build": "npm run chrome-extension:prerequisites && npm run chrome-extension:build && npm run self:build"
  },
  "devDependencies": {
    "typescript": "5.9.2",
    "@types/node": "22.17.1",
    "@types/adm-zip": "0.5.8",
    "jest": "30.2.0"
  },
  "dependencies": {
    "fast-xml-parser": "5.9.3",
    "adm-zip": "0.5.17",
    "@picteus/internal-extension-sdk": "0.13.0"
  }
}
