{
  "name": "@picteus/image-commons",
  "version": "1.1.0",
  "productName": "Image Commons",
  "description": "Proposes common operations on images.",
  "keywords": [
    "picteus",
    "extension",
    "typescript",
    "image"
  ],
  "author": {
    "name": "Édouard Mercier",
    "email": "edouard@koppasoft.com",
    "url": "https://github.com/edouardmercier"
  },
  "license": "GNU Affero General Public License",
  "private": false,
  "engines": {
    "node": ">=22.17.1"
  },
  "homepage": "https://github.com/picteus/Picteus",
  "repository": {
    "type": "git",
    "url": "https://github.com/picteus/Picteus.git"
  },
  "bugs": {
    "url": "https://github.com/picteus/Picteus/issues"
  },
  "type": "module",
  "main": "./dist/back-end/main.js",
  "files": [
    "dist",
    "manifest.json",
    "icon.png"
  ],
  "scripts": {
    "prepare": "cd front-end && npm --no-save install",
    "back-end:build": "tsc --project back-end/tsconfig.json",
    "front-end:build": "npm --prefix front-end run build",
    "build": "npm run back-end:build && npm run front-end:build"
  },
  "devDependencies": {
    "typescript": "5.9.2",
    "@types/node": "22.17.1"
  },
  "dependencies": {
    "@picteus/internal-extension-sdk": "0.11.0"
  }
}
