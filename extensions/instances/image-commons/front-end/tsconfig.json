{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Node",
    "target": "ES2022",
    "baseUrl": "./src",
    "jsx": "react",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "~*": [
        "./*"
      ]
    },
    "strict": true,
    "declaration": false
  },
  "include": [
    "src/**/*"
  ]
}
